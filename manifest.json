{
  "manifest_version": 3,
  "name": "Tathya-Satyapan",
  "version": "1.0.0",
  "description": "Detect misleading Instagram claims in real time using AI.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icons16.png",
    "48": "icons/icons48.png",
    "128": "icons/icons128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tathya-Satyapan Settings"
  }
}